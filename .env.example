# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE_URL=https://api.openai.com/v1

# API Mode: "openai" (default, uses OpenAI SDK) or "proxy" (direct fetch to proxy URLs)
# IMAGE_API_MODE=openai

# Proxy Configuration (only used when IMAGE_API_MODE=proxy)
# IMAGE_API_MODE=proxy
# PROXY_BASE_URL=http://localhost:5219
# PROXY_API_VERSION=2025-04-01-preview

# Next.js Configuration
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
